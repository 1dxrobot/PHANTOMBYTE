# ── PhantomByte Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values

SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# Gmail SMTP (use App Password, not your real password)
# Guide: myaccount.google.com → Security → App Passwords
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# Fernet key — generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here
